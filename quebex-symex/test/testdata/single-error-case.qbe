export
function $__assert_fail() {
@start.1
@body.2
	hlt
}
function w $first_divisor(w %.1) {
@start.3
	%.2 =l alloc4 4
	storew %.1, %.2
	%.3 =l alloc4 4
@body.4
	storew 2, %.3
@for_cond.5
	%.4 =w loadw %.3
	%.5 =w loadw %.2
	%.6 =w csltw %.4, %.5
	jnz %.6, @for_body.6, @for_join.8
@for_body.6
	%.7 =w loadw %.2
	%.8 =w loadw %.3
	%.9 =w rem %.7, %.8
	%.10 =w ceqw %.9, 0
	jnz %.10, @if_true.9, @if_false.10
@if_true.9
	%.11 =w loadw %.3
	ret %.11
@if_false.10
@for_cont.7
	%.12 =w loadw %.3
	%.13 =w add %.12, 1
	storew %.13, %.3
	jmp @for_cond.5
@for_join.8
	%.14 =w loadw %.2
	ret %.14
}
data $.Lstring.4 = align 1 { b "prime\000", }
export
function w $main() {
@start.11
	%.1 =l alloc4 4
@body.12
	%.2 =l extsw 1
	call $quebex_make_symbolic(l %.1, l %.2, l 4, l $.Lstring.4)
	%.3 =w loadw %.1
	%.4 =w cslew %.3, 50
	jnz %.4, @if_true.13, @if_false.14
@if_true.13
	%.5 =w loadw %.1
	%.6 =w csgtw %.5, 1
	jnz %.6, @logic_right.15, @logic_join.16
@logic_right.15
	%.7 =w loadw %.1
	%.8 =w call $first_divisor(w %.7)
	%.9 =w loadw %.1
	%.10 =w ceqw %.8, %.9
	%.11 =w cnew %.10, 0
@logic_join.16
	%.12 =w phi @if_true.13 0, @logic_right.15 %.11
	jnz %.12, @if_true.17, @if_false.18
@if_true.17
	%.13 =w loadw %.1
	%.14 =w cnew %.13, 43
	jnz %.14, @logic_join.20, @logic_right.19
@logic_right.19
	call $__assert_fail()
	hlt
@dead.21
	%.15 =w cnew 0, 0
@logic_join.20
	%.16 =w phi @if_true.17 1, @dead.21 %.15
	ret 1
@if_false.18
	ret 0
@if_join.22
@if_false.14
	ret 0
}
